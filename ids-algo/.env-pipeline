# ================================
# AI Powered IDS - Pipeline配置
# ================================

# --------------------------------
# 基础应用配置
# --------------------------------
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# --------------------------------
# LLM服务配置
# --------------------------------

# 当前使用的提供商 (openrouter | anthropic)
LLM_PROVIDER=anthropic

# OpenRouter配置 (备用)
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic直连配置 (当前使用)
ANTHROPIC_AUTH_TOKEN=sk-d2c34707eb1a890aa86061cd84ccd8574ee13da991963d01459a3e4095744c17
ANTHROPIC_BASE_URL=https://cc-vibe.com

# 通用配置
LLM_API_KEY=sk-d2c34707eb1a890aa86061cd84ccd8574ee13da991963d01459a3e4095744c17
LLM_BASE_URL=https://cc-vibe.com
LLM_TIMEOUT=60

# --------------------------------
# 分阶段LLM模型配置
# --------------------------------

# 阶段1: 结构化解析器 (语义理解)
PARSER_LLM_MODEL=claude-3-5-sonnet-20241022
PARSER_LLM_TEMPERATURE=0.1
PARSER_LLM_MAX_TOKENS=2048

# 阶段2: Facet分类器 (IDS分类)
CLASSIFIER_LLM_MODEL=claude-3-5-sonnet-20241022
CLASSIFIER_LLM_TEMPERATURE=0.05
CLASSIFIER_LLM_MAX_TOKENS=1024

# 阶段4: PropertySet选择器 (约束验证)
PROPERTYSET_LLM_MODEL=claude-3-5-sonnet-20241022
PROPERTYSET_LLM_TEMPERATURE=0.0
PROPERTYSET_LLM_MAX_TOKENS=512

# --------------------------------
# 向量数据库配置
# --------------------------------

# Entity知识库嵌入模型
ENTITY_EMBEDDING_MODEL=BAAI/bge-m3
# Property知识库嵌入模型
PROPERTY_EMBEDDING_MODEL=BAAI/bge-m3
# 向量维度 (BGE-M3: 1024, BGE-base: 768)
VECTOR_DIM=1024
# 语义匹配阈值
SEMANTIC_MATCHING_THRESHOLD=0.7

# --------------------------------
# Prompt配置
# --------------------------------
PARSER_PROMPT_VERSION=v1
CLASSIFIER_PROMPT_VERSION=v1
PROPERTYSET_PROMPT_VERSION=v1
PROMPT_LANGUAGE=en

# --------------------------------
# 外部API配置
# --------------------------------

# IFC Entity PropertySet API
IFC_ENTITY_PSET_API_URL=http://36.103.199.7:5000/api/property/entity-psets

# # bSDD数据字典API
# BSDD_API_URL=https://api.bsdd.buildingsmart.org
# BSDD_LANGUAGE=zh-CN
# BSDD_MAX_RESULTS=5
# # bSDD分类查询 (外部词典集成)
# ENABLE_BSDD_CLASSIFICATION=true


# --------------------------------
# Pipeline流程开关
# --------------------------------

# 抽象实体检查 (过滤没有PropertySet的实体)
ENABLE_ENTITY_CONCRETENESS_CHECK=true

# PropertySet验证 (确保Property属于Entity的PropertySet)
ENABLE_PROPERTYSET_VALIDATION=true



# --------------------------------
# 性能和监控配置
# --------------------------------

# 向量缓存配置
ENABLE_CACHE=true                         # 启用向量缓存
CACHE_TTL=3600                           # 缓存TTL(秒)
CACHE_MAX_MEMORY_SIZE=10000              # 内存缓存最大条目数
CACHE_DIR=./cache/vectors                # 缓存目录
CACHE_ENABLE_PERSISTENCE=true            # 启用磁盘持久化

# 性能日志
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_INTERMEDIATE_RESULTS_LOGGING=false

# 监控配置
ENABLE_MONITORING=true
MONITORING_REFRESH_INTERVAL=5
STATS_RETENTION_DAYS=30

# --------------------------------
# 错误和输出配置
# --------------------------------
OUTPUT_DIR=output
ERROR_LOG_DIR=output/extraction_errors
MAX_ERROR_LOGS=1000
EXTRACTION_LOG_LEVEL=INFO

# --------------------------------
# CORS配置 (生产环境请限制域名)
# --------------------------------
CORS_ORIGINS=["*"]



MONGODB_URI="mongodb+srv://haoyuwang:770122@cluster0.maypzsy.mongodb.net/IDS-agent?appName=Cluster0"
