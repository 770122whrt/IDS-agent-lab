      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcVibrationIsolator",
      "definition": "A vibration isolator is a device used to minimize the effects of vibration transmissibility in a structure.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcVibrationIsolatorType",
