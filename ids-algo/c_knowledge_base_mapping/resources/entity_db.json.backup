    },
    {
      "name": "IfcAirTerminal",
      "definition": "An air terminal is a terminating or origination point for the transfer of air between distribution system(s) and one or more spaces. It can also be used for the transfer of air between adjacent spaces.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcAirTerminalBox",
      "definition": "An air terminal box typically participates in an HVAC duct distribution system and is used to control or modulate the amount of air delivered to its downstream ductwork. An air terminal box type is often referred to as an \"air flow regulator\".",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcAirTerminalBoxType",
      "definition": "The flow controller type **IfcAirTerminalBoxType** defines commonly shared information for occurrences of air terminal boxes. The set of shared information may include:\\n\\n* common properties with shared property sets\\n* common representations\\n* common materials\\n* common composition of elements\\n* common ports",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcAirTerminalType",
      "definition": "The flow terminal type **IfcAirTerminalType** defines commonly shared information for occurrences of air terminals. The set of shared information may include:\\n\\n* common properties with shared property sets\\n* common representations\\n* common materials\\n* common composition of elements\\n* common ports",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcAirToAirHeatRecovery",
      "definition": "An air-to-air heat recovery device employs a counter-flow heat exchanger between inbound and outbound air flow. It is typically used to transfer heat from warmer air in one chamber to cooler air in the second chamber (i.e., typically used to recover heat from the conditioned air being exhausted and the outside air being supplied to a building), resulting in energy savings from reduced heating (or cooling) requirements.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcAirToAirHeatRecoveryType",
      "definition": "The energy conversion device type **IfcAirToAirHeatRecoveryType** defines commonly shared information for occurrences of air to air heat recoverys. The set of shared information may include:\\n\\n* common properties with shared property sets\\n* common representations\\n* common materials\\n* common composition of elements\\n* common ports",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcBoiler",
      "definition": "A boiler is a closed, pressure-rated vessel in which water or other fluid is heated using an energy source such as natural gas, heating oil, or electricity. The fluid in the vessel is then circulated out of the boiler for use in various processes or heating applications.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcBoilerType",
