      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcMarinePart",
      "definition": "Part of a marine facility.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcMooringDevice",
      "definition": "A mooring device is an active or passive built element who's primary function is to participate in the mooring of a vessel, this could be in the form of a bollard used as an attachment point for lines or active equipment such as quick release hooks.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcMooringDeviceType",
      "definition": "The _IfcMooringDeviceType_ provides the type information for _IfcMooringDevice_ occurrences.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcNavigationElement",
      "definition": "A navigation element is an active or passive built element who's primary function is to provide navigational instructions and warnings to vessels, this could be in the form of a floating buoy, a fixed beacon.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcNavigationElementType",
      "definition": "The _IfcNavigationElementType_ provides the type information for _IfcNavigationElement_ occurrences.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcRail",
      "definition": "A rail is a predominately linear built element that has a special section profile. Rail is distinctive from built elements with similar geometric shapes (e.g. beam, member) that its major function is to ensure guidance of moving for vehicles or other kinds of machineries.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcRailType",
      "definition": "The element type _IfcRailType_ defines commonly shared information for occurrences of rails. The set of shared information may include:\\n* common properties within shared property sets\\n* common material information\\n* common profile definitions\\n* common shape representations",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcRailway",
      "definition": "An IfcRailway is a spatial structure element as a route from one location to another for guided passage of wheeled vehicles on rails. An IfcRailway acts as a basic spatial structure element that supports to break down a railway project into manageable parts.",
      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcRailwayPart",
