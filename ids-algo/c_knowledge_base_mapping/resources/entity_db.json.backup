      "ifc_version": "IFC4X3",
      "item_type": "entity",
      "predefined_types": []
    },
    {
      "name": "IfcMarineFacility",
      "definition": "A marine facility represents any major structure or entity that is specific to the ports and waterways domain. examples of this include quays, jetties, shipyards, breakwaters etc.",
