<ids:ids xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://standards.buildingsmart.org/IDS http://standards.buildingsmart.org/IDS/1.0/ids.xsd" xmlns:ids="http://standards.buildingsmart.org/IDS">
  <!--edited with usBIM.IDSeditor 2.3.4.0 (http://www.accasoftware.com)-->
  <ids:info>
    <ids:title>TI Bridge IDS file</ids:title>
    <ids:version>1.0</ids:version>
    <ids:author>lars.wikstrom@triona.se</ids:author>
    <ids:date>2025-02-17</ids:date>
    <ids:purpose>Encoding the Bridge RAR into an IDS</ids:purpose>
  </ids:info>
  <ids:specifications>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Project" description="All data sets shall consist of a single IfcProject instance, which identifies the overall project, provides defaults for units, and holds a graph of references to all data within scope.&#xA;&#xA;Can't see any possibilities to have unit requirements in IDS.&#xA;The RAR spoecifies:&#xA;- Length Unit: Default unit for length. For imperial, inches are recommended. SI Meters are thedefault if not provided.&#xA;- Angle Unit: Default unit for angles. Degrees are recommended, and are the default if not provided.&#xA;- Mass Unit: Default unit for mass. For imperial, pounds are recommended. SI Kilograms are the default if not provided.&#xA;Temperature Unit: Default unit for temperature. For imperial, fahrenheit is recommended. SI Celcius is the default if not provided.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPROJECT</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements />
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Site" description="Data sets shall include at least one site. The site may define existing and proposed terrain within vicinity of the bridge project and contain alignment(s), bridge(s) and potentially other structures such as the road/rail supported by the bridge. Boring points may be included as objects contained within the site.&#xA;&#xA;Comment: The RAR specifies a mandatory Site. However here it is made optional. Also the reference elevation is required in the RAR. However, the reference elevation should be present in the CRS reference.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCSITE</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCPROJECT</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the site for referencing purposes.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Bridge" description="Each bridge structure is captured within a definition describing the span location of a bridge relative to an alignment. The extents of the bridge are defined using an Axis curve, where IfcOffsetCurveByDistances would fit most scenarios – referencing an IfcAlignmentCurve with starting and ending distances along the curve, and typically no laterial or vertical offsets.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBRIDGE</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <xs:restriction base="xs:string">
                <xs:enumeration value="IFCBRIDGE" />
                <xs:enumeration value="IFCPROJECT" />
              </xs:restriction>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Alignment" description="Horizontal and vertical alignment curves provide the underlying placement for all&#xA;components in a bridge plan.&#xA;&#xA;Missing: Axis, Placement (not possible in IDS)">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCALIGNMENT</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCPROJECT</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Substructure" description="The substructure of a bridge refers to elements that transfer loads into the ground.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>SUBSTRUCTURE</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGE</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Superstructure" description="The superstructure of a bridge refers to those elements than span horizontally to carry loads onto substructures.&#xA;&#xA;Missing: Alignments">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>SUPERSTRUCTURE</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGE</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Girders">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>GIRDER</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUPERSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Deck" description="A bridge deck is comprised of those elements used for conveying traffic but do not perform structural functions of the superstructure.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>DECK</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGE</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Deck segments">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>DECK_SEGMENT</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>DECK</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Abutments" description="Abutments refer to substructures at the ends of a bridge. They may be composed of wing walls (on each side), head wall, stem wall, and cone.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>ABUTMENT</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUBSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:applicability>
      <ids:requirements />
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Piers" description="Piers are decomposed into elements according to connectivity, indicating construction joints. Reinforcing may be indicated within inner elements such as footings, columns, members, and walls (see documentation at corresponding elements for usage); such reinforcing shouldreflect how it is to be placed at time of construction such that rebar connecting between elements is projected out of the element where it is initially placed.&#xA;Abutments and piers are placed relative to the horizontal alignment curve (NOT the vertical alignment curve), with components placed according to Cartesian placement within. This reflects positioning as typically indicated on construction plans, where all dimension lines are based on Cartesian positioning relative to the position and orientation of the station along the horizontal alignment curve.&#xA;&#xA;Missing: Alignment, Location (not possible with IDS)">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>PIER</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUBSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Piles">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPILE</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Surface Proposed" description="The ground surface of the site indicating final conditions.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <xs:restriction base="xs:string">
              <xs:enumeration value="IFCGEOMODEL" />
              <xs:enumeration value="IFCGEOGRAPHICELEMENT" />
            </xs:restriction>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <xs:restriction base="xs:string">
                <xs:enumeration value="IFCSITE" />
                <xs:enumeration value="IFCBRIDGE" />
              </xs:restriction>
            </ids:name>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Surface Existing" description="The ground surface of the site indicating existing conditions.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <xs:restriction base="xs:string">
              <xs:enumeration value="IFCGEOMODEL" />
              <xs:enumeration value="IFCGEOGRAPHICELEMENT" />
            </xs:restriction>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <xs:restriction base="xs:string">
                <xs:enumeration value="IFCSITE" />
                <xs:enumeration value="IFCBRIDGE" />
              </xs:restriction>
            </ids:name>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Boring Points (IfcGeographicElement)" description="Boring points indicating soil layers and properties at discrete locations.&#xA;Site grading is indicated using several geometric structures, for which contour lines or the elevation at any point may be derived. The IfcGeographicElement entity with&#xA;PredefinedType set to SOILBORING (new) may be used to indicate soil borings at particular points.&#xA;&#xA;Missing: Location (not possible in IDS)">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCGEOGRAPHICELEMENT</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>SOIL_BORING_POINT</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <xs:restriction base="xs:string">
                <xs:enumeration value="IFCSITE" />
                <xs:enumeration value="IFCBRIDGE" />
              </xs:restriction>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Material" description="Materials are defined on elements to be constructed (e.g. concrete), fabricated (e.g. steel girders), and that exist on site (e.g. soil borings), indicating material category, classification, and structural properties.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCMATERIAL</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Material classification according to the respective authority (e.g. ASTM)">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Category of material, where if provided must be one of &quot;Steel&quot;, &quot;Concrete&quot;, &quot;Wood&quot;, &quot;Plastic&quot;, &quot;Glass&quot;, &quot;Earth&quot;.">
          <ids:name>
            <ids:simpleValue>Category</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Concrete" />
              <xs:enumeration value="Steel" />
              <xs:enumeration value="Wood" />
              <xs:enumeration value="Plastic" />
              <xs:enumeration value="Glass" />
              <xs:enumeration value="Earth" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:property dataType="IFCMASSDENSITYMEASURE" cardinality="optional" instructions="Material mass density.">
          <ids:propertySet>
            <ids:simpleValue>Pset_MaterialCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>MassDensity</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCMODULUSOFELASTICITYMEASURE" cardinality="optional" instructions="A measure of the Young's modulus of elasticity of the material.">
          <ids:propertySet>
            <ids:simpleValue>Pset_MaterialMechanical</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>YoungModulus</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCMODULUSOFELASTICITYMEASURE" cardinality="optional" instructions="A measure of the shear modulus of elasticity of the material.">
          <ids:propertySet>
            <ids:simpleValue>Pset_MaterialMechanical</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>ShearModulus</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCTHERMALEXPANSIONCOEFFICIENTMEASURE" cardinality="optional" instructions="A measure of the expansion coefficient for warming up the material about one Kelvin.">
          <ids:propertySet>
            <ids:simpleValue>Pset_MaterialMechanical</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>ThermalExpansionCoefficient</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCPRESSUREMEASURE" cardinality="optional" instructions="[If Category=”Concrete”] The compressive strength of the concrete.">
          <ids:propertySet>
            <ids:simpleValue>Pset_MaterialConcrete</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>CompressiveStrength</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCPRESSUREMEASURE" cardinality="optional" instructions="[If Category=”Steel”] A measure of the yield stress (or characteristic 0.2 percent proof stress) of the material.">
          <ids:propertySet>
            <ids:simpleValue>Pset_MaterialSteel</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>YieldStress</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Pier Stems" description="Each pier may have one or more stems, separated laterally.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCCOLUMN</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>PIERSTEM</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>PIER</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Pier Segments" description="Each pier stem may have one or more segments, separated by construction joint.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCCOLUMN</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>PIERSTEM_SEGMENT</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCCOLUMN</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>PIERSTEM</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Pier Caps" description="Each pier may have a top that spans stem(s). If such cap is above a bearing, then it is modelled as part of the superstructure.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBEAM</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>PIERCAP</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="SUBSTRUCTURE" />
                <xs:enumeration value="SUPERSTRUCTURE" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Retaining Walls" description="Retaining walls refer to wall structures for retaining soil.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCWALL</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>RETAININGWALL</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUBSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Apron" description="A bridge apron is a device to protect a river bank or river bed against scour; a shield (source: http://sdrc.lib.uiowa.edu/eng/bridges/WaddellGlossary/GlossA.htm).">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBUILDINGELEMENTPART</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>APRON</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUBSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Arch" description="An arch refers to a hyperbolic member that supports vertical loads at intervals along its span.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>ARCH</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUBSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Footing" description="Footings are typically described geometrically by enclosed polygonal areas extruded&#xA;vertically according to footing depth. For stepped footings, multiple extruded solids may be used, however they must not intersect.&#xA;&#xA;Missing: Geometry, Connection to Piles, Reinforcing&#xA;&#xA;Piles supporting footings are linked according to a connection relationship.&#xA;Reinforcing is typically modelled as aggregation of Footing - Footing/Reinforcement">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCFOOTING</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>PAD_FOOTING</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="SUBSTRUCTURE" />
                <xs:enumeration value="FOUNDATION" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the footing for referencing purposes, as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" instructions="Material properties of the footing, indicating concrete strength." />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Pile" description="Piles are typically described geometrically by a circular profile extruded vertically according to pile depth. For multiple piles, mapped representation may be used to efficiently place piles of similar dimensions in multiple locations.&#xA;&#xA;Missing: Cross section, Batter&#xA;&#xA;Piles supporting footings are linked according to a connection relationship.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPILE</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUBSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of pile arrangement for referencing purposes, as found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" instructions="Material of piles." />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Hat Stone" description="Hat Stone refers to a top course on an abutment or culvert.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBEAM</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>HATSTONE</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements />
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Girder" description="Bridge girders refer to horizontal support beams that span along the alignment of a bridge.&#xA;&#xA;For steel girders, this refers to each girder line, decomposed into beam segments.&#xA;For concrete box girders, this refers to the overall box girder, typically connected to the bridge deck via a keyed construction joint with adjoining reinforcing.&#xA;&#xA;Missing: Alignment, Axis, IfcRelDefinesByType">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>GIRDER</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUPERSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the girder line for referencing purposes as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Boring Points 2 (IfcBorehole)" description="Boring points indicating soil layers and properties at discrete locations.&#xA;Site grading is indicated using several geometric structures, for which contour lines or the elevation at any point may be derived. The IfcGeographicElement entity with&#xA;PredefinedType set to SOILBORING (new) may be used to indicate soil borings at particular points.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBOREHOLE</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <xs:restriction base="xs:string">
                <xs:enumeration value="IFCSITE" />
                <xs:enumeration value="IFCBRIDGE" />
              </xs:restriction>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Girder Type" description="Template defining general construction that may be used across projects.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLYTYPE</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>GIRDER</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Girder Segment" description="Girder segments refer to discrete sections along a girder line. They may be modelled as one object that encapsulates the overall cross section (e.g. I-Shape steel, arbitrary precast profile), or as separate objects (e.g. steel flange plates, steel web plate). Each segment may have a constant cross section, a tapered cross section (linearly interpolated from start to end), a variable cross section (linearly interpolated at multiple points between start and end), or free-form geometry.&#xA;&#xA;Missing: Solid Geometry, Connection*, Reinforcing. Tendons, Camber, Stiffeners, Shear Studs">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBEAM</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>GIRDER_SEGMENT</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <xs:restriction base="xs:string">
                <xs:enumeration value="IFCELEMENTASSEMBLY" />
                <xs:enumeration value="IFCELEMENTASSEMBLYTYPE" />
              </xs:restriction>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>GIRDER</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the girder segment for referencing purposes as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Plates" description="Built-up girders may be decomposed into plates (or members) for web, flanges, cover plates, longitudinal stiffeners, and vertical stiffeners.&#xA;&#xA;Comment: Not adding any partOf requirements since plates and members can occur in different assamblies (e.g. also railings).">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPLATE</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements />
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Cross Frame" description="Bridge cross frames connect two girders laterally.&#xA;Cross-framing between girders may be described using templates of member configurations. Such cross framing is captured within components, using standard shapes (e.g. AISC in U.S.) where applicable. For curved alignments where girders are placed at different elevations, members must be placed relative to the girders at each side, for which positioning is defined relative to alignment curves.&#xA;&#xA;Missing: Position (not possible in IDS), Girder Segment Left/Right (not possible in IDS">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>CROSS_BRACING</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Name of cross frame occurrence as would be identified on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Diaphragm" description="Diaphragms refer to sections of bridge girders immediately above supporting structures that provide additional lateral and vertical support.&#xA;Diaphragms are modeled similarly as concrete girder segments, except are distinguished according to a predefined type (e.g. IfcBeamTypeEnum.DIAPHRAGM), and have connections to underlying supports.&#xA;&#xA;Missing: Solid geometry, Connection*, Reinforcing, Tendons">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBEAM</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>DIAPHRAGM</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>SUPERSTRUCTURE</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the diaphragm for referencing purposes as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Truss" description="Trusses refer to a framework of linear structural elements in tension and compression for supporting the span of a bridge superstructure. Within a truss, struts refer to compression elements, and ties refer to tension elements.&#xA;&#xA;Missing: Connections. Also specified IfcPlate generically (without GUSSET_PLATE PDT) as part of a truss.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>TRUSS</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Deck Span" description="Bridge deck spans represent the surface of a bridge. They may be decomposed into&#xA;segments and components.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELEMENTASSEMBLY</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>DECK</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="DECK" />
                <xs:enumeration value="DECK_SEGMENT" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Deck Segment" description="This entity may be used to model segments of a bridge deck, separated by construction orexpansion joint. Geometry for bridge decks is typically represented using IfcSectionedSolidHorizontal for defining a cross section that may potentially vary along an alignment.&#xA;&#xA;Comment: Geometric requirements, connection reqirements, reinforcing and drainage.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>DECK_SEGMENT</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <ids:simpleValue>DECK</ids:simpleValue>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the deck segment for referencing purposes as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" instructions="Material of the deck segment." />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Parapet" description="This entity may be used to model barriers of constant cross-section, or architectural railings.&#xA;&#xA;Barriers may be defined as a constant cross-section placed along the alignment at either edge of a bridge deck or anywhere in between.&#xA;&#xA;Comment: Geometry, Connections, Reinforcing, Conduit">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCWALL</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>PARAPET</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="DECK" />
                <xs:enumeration value="DECK_SEGMENT" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the parapet segment for referencing purposes as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" instructions="Material of the parapet." />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Railing" description="This entity may be used to model barriers of constant cross-section, or architectural railings.&#xA;&#xA;Barriers may be defined as a constant cross-section placed along the alignment at either edge of a bridge deck or anywhere in between.&#xA;&#xA;Comment: Geometry, Connections, Reinforcing, Conduit">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCRAILING</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>GUARDRAIL</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="DECK" />
                <xs:enumeration value="DECK_SEGMENT" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name of the railing segment for referencing purposes as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:material cardinality="required" instructions="Material of the railing." />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Approach slab" description="An approach slab refers to a slab providing transition between a bridge and road pavement, where an expansion joint allows for differential settlement, temperature changes, and freeze/thaw effects.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCSLAB</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>APPROACH_SLAB</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="DECK" />
                <xs:enumeration value="DECK_SEGMENT" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Cornice" description="A cornice is construction eveloping the sides of a bridge protecting the deck.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBEAM</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>CORNICE</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="DECK" />
                <xs:enumeration value="DECK_SEGMENT" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Waterproofing" description="Waterproofing membranes are applied on top of deck segments.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCCOVERING</ids:simpleValue>
          </ids:name>
          <ids:predefinedType>
            <ids:simpleValue>MEMBRANE</ids:simpleValue>
          </ids:predefinedType>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBRIDGEPART</ids:simpleValue>
            </ids:name>
            <ids:predefinedType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="DECK" />
                <xs:enumeration value="DECK_SEGMENT" />
              </xs:restriction>
            </ids:predefinedType>
          </ids:entity>
        </ids:partOf>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Bearing" description="Bearings refer to elements connecting substructure elements to superstructure elements where movement is allowed along one or more degrees of freedom.&#xA;&#xA;Comment: Type relationship, Mechanical constraint, Connections">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBEARING</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Name of bearing for referencing purposes as would be found on construction plans.">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4X3_ADD2" name="Bearing type" description="Type of bearing, where common geometry and properties may be defined.&#xA;&#xA;Comment: Occurrence relationship, Mechanical constraint">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
