  <ids:specifications>
    <ids:specification name="Building Story Level Naming Convention" ifcVersion="IFC4X3_ADD2 IFC4 IFC2X3" description="Validates that building stories follow the specified naming pattern for ground floor, first floor, and second floor designations.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBUILDINGSTOREY</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="00 ground floor"/>
              <xs:enumeration value="01 first floor"/>
              <xs:enumeration value="02 second floor"/>
            </xs:restriction>
          </ids:value>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
  </ids:specifications>
